{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C Program",
            "type": "shell",
            "command": "gcc",
            "args": [
                "${workspaceFolder}\\array_operations.c",
                "-o",
                "${workspaceFolder}\\array_operations.exe",
                "-Wall"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "Build and Run",
            "type": "shell",
            "command": "gcc ${workspaceFolder}\\array_operations.c -o ${workspaceFolder}\\array_operations.exe -Wall && start cmd /k ${workspaceFolder}\\array_operations.exe",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        }
    ]
}
